# The port number for the Authentication microservice.
PORT=

# The gRPC address for the Notification service.
NOTIF_GRPC_URL=
# A secret key used for HMAC-based token signing and verification.
# High-entropy random string recommended.
HMAC_SECRET=your_hmac_secret_here

# The current environment of the application (e.g., development, production, test).
NODE_ENV=

# URL for the Redis server used for token management or sessions.
REDIS_URL=

# Connection string for the MySQL database used by the authentication service.
# Format: mysql://user:password@host:port/database
DATABASE_URL=
