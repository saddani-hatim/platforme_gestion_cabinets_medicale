# The port number for the gRPC Notification service.
GRPC_PORT=

# Secret key for gRPC communication security, should match authentication service.
HMAC_SECRET=your_hmac_secret_here

# SMTP host for sending emails (e.g., smtp.gmail.com).
EMAIL_HOST=smtp.gmail.com

# SMTP port (e.g., 587 for TLS, 465 for SSL).
EMAIL_PORT=587

# Use SSL/TLS for SMTP connection (true/false).
EMAIL_SECURE=false

# Email address used as the sender for notifications.
EMAIL_USER=your_email@gmail.com

# Password or app-specific password for the email account.
EMAIL_PASS=your_email_password
